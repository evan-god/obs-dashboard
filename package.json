{
  "name": "obs-dashboard",
  "version": "1.6.2",
  "description": "OBS 直播间监控大盘 - 多路直播监控桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "start": "node_modules/electron/dist/electron.exe .",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.obs.dashboard",
    "productName": "OBS直播间监控大盘",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "obs-dashboard.html",
      "!node_modules",
      "!novels",
      "!dist",
      "!*.md",
      "!*.png",
      "!*.pptx",
      "!*.py",
      "!*.bat"
    ],
    "extraResources": [
      {
        "from": "obs-log-service.js",
        "to": "deploy/obs-log-service.js"
      },
      {
        "from": "install-obs-log-service.bat",
        "to": "deploy/install-obs-log-service.bat"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OBS 监控大盘",
      "installerIcon": null,
      "uninstallDisplayName": "OBS 直播间监控大盘",
      "installerHeaderIcon": null,
      "warningsAsErrors": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  }
}
