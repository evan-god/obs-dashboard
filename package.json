{
  "name": "obs-dashboard",
  "version": "1.3.0",
  "description": "OBS 直播间监控大盘 - 桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "start": "node_modules/electron/dist/electron.exe .",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.obs.dashboard",
    "productName": "OBS直播间监控大盘",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "obs-dashboard.html",
      "!node_modules",
      "!novels",
      "!dist",
      "!*.md",
      "!*.png",
      "!*.pptx",
      "!*.py",
      "!*.bat"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "OBS 监控大盘"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  }
}
